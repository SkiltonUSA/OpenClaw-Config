# Travel API credentials template (safe to commit)
# Copy to `.env.travel` and fill with real values.
# Never commit real secrets.

# RapidAPI
RAPIDAPI_KEY=replace_with_rotated_key

# Booking.com flights (RapidAPI marketplace host)
BOOKING_RAPIDAPI_HOST=booking-com18.p.rapidapi.com

# Flights Sky details/search (RapidAPI marketplace host)
FLIGHTS_SKY_RAPIDAPI_HOST=flights-sky.p.rapidapi.com

# Yahoo Weather (RapidAPI marketplace host)
YAHOO_WEATHER_RAPIDAPI_HOST=yahoo-weather5.p.rapidapi.com

# Airbnb listings (RapidAPI marketplace host)
AIRBNB_RAPIDAPI_HOST=airbnb19.p.rapidapi.com

# Tourist attractions (RapidAPI marketplace host)
TOURIST_ATTRACTION_RAPIDAPI_HOST=tourist-attraction.p.rapidapi.com

# Optional future provider tokens (prefer OAuth/token flows over passwords)
BOOKING_OAUTH_ACCESS_TOKEN=
EXPEDIA_OAUTH_ACCESS_TOKEN=
AMADEUS_ACCESS_TOKEN=

# Optional account metadata (non-secret)
TRAVEL_PROFILE_NAME=
TRAVEL_HOME_AIRPORT=
TRAVEL_PREFERRED_CABIN=economy
